{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GwenLand ADE",
  "version": "0.1.1",
  "identifier": "dev.gwenland.ade",
  "build": {
    "frontendDist": "../ade-ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "cd ../ade-ui && pnpm dev",
    "beforeBuildCommand": "cd ../ade-ui && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "GwenLand ADE",
        "width": 1024,
        "height": 720,
        "minWidth": 600,
        "minHeight": 480,
        "decorations": false,
        "center": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
